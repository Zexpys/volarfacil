{
  "name": "volarfacil-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "node -e \"const fs=require('fs');const p=require.resolve('metro/package.json');const pkg=JSON.parse(fs.readFileSync(p,'utf8'));if(pkg.exports&&!pkg.exports['./src/lib/TerminalReporter']){pkg.exports['./src/lib/TerminalReporter']='./src/lib/TerminalReporter.js';fs.writeFileSync(p,JSON.stringify(pkg));console.log('Patched metro exports')}\""
  },
  "dependencies": {
    "expo": "~52.0.36",
    "expo-router": "~4.0.17",
    "expo-status-bar": "~2.0.1",
    "expo-notifications": "~0.29.14",
    "expo-device": "~7.0.2",
    "expo-constants": "~17.0.8",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "@supabase/supabase-js": "^2.49.4",
    "@react-native-async-storage/async-storage": "2.1.2",
    "react-native-url-polyfill": "^2.0.0",
    "nativewind": "^4.1.23",
    "tailwindcss": "^3.4.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "@react-navigation/native": "^7.0.14",
    "expo-linking": "~7.0.5",
    "expo-splash-screen": "~0.29.22"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "engines": {
    "node": "20.x"
  }
}
